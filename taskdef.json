{
  "family": "BlueGreenTask",
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::158565517012:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "bluegreen",
      "image": "<IMAGE1_NAME>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80
        }
      ]
    }
  ]
}